                  <div>
                    <div class="font-medium text-white">Authentification Admin</div>
                    <div class="text-xs text-[#A8B0C2]">Token sécurisé en session</div>
                  </div>
                  <span class="px-2 py-1 rounded bg-[#10B981]/20 text-[#10B981] text-xs">Actif</span>
                </div>
                
                <div class="flex items-center justify-between p-4 rounded-xl bg-black/20">
                  <div>
                    <div class="font-medium text-white">Stripe Secret Key</div>
                    <div class="text-xs text-[#A8B0C2]">Stockée côté serveur uniquement</div>
                  </div>
                  <span class="px-2 py-1 rounded bg-[#10B981]/20 text-[#10B981] text-xs">Sécurisé</span>
                </div>
              </div>
            </div>

            <div class="glass-panel rounded-2xl p-6">
              <h3 class="font-bold text-xl mb-6 text-[#EF4444]">Zone dangereuse</h3>
              <div class="space-y-3">
                <button onclick="app.exportData('full')" class="w-full p-3 rounded-xl border border-[rgba(255,255,255,0.12)] hover:bg-white/5 text-left flex items-center gap-3 text-white">
                  <i class="fas fa-download text-[#D6B15E]"></i>
                  <div>
                    <div class="font-medium">Exporter toutes les données</div>
                    <div class="text-xs text-[#A8B0C2]">Backup JSON complet</div>
                  </div>
                </button>
                <button onclick="app.logout()" class="w-full p-3 rounded-xl border border-[#EF4444]/30 hover:bg-[#EF4444]/10 text-left flex items-center gap-3 text-[#EF4444]">
                  <i class="fas fa-sign-out-alt"></i>
                  <div>
                    <div class="font-medium">Déconnexion</div>
                    <div class="text-xs text-[#EF4444]/70">Terminer la session</div>
                  </div>
                </button>
              </div>
            </div>
          </div>
        `;
      },

      // ACTIONS DEVIS
      async submitQuote(e) {
        e.preventDefault();
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData);
        
        const btn = document.getElementById('submitQuoteBtn');
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Envoi...';
        btn.disabled = true;

        try {
          const response = await this.apiCall('/create-quote', {
            method: 'POST',
            body: JSON.stringify(data)
          });

          if (response.ok) {
            this.showToast('Devis créé et envoyé avec succès !', 'success');
            this.closeModal('newQuote');
            e.target.reset();
            this.navigate('quotes');
          } else {
            const error = await response.json();
            this.showToast(error.error || 'Erreur lors de la création', 'error');
          }
        } catch (error) {
          this.showToast('Erreur réseau : ' + error.message, 'error');
        } finally {
          btn.innerHTML = originalText;
          btn.disabled = false;
        }
      },

      async viewQuote(quoteId) {
        try {
          const response = await this.apiCall(`/admin-get-quote?id=${quoteId}`);
          const quote = await response.json();
          state.currentQuote = quote;
          
          document.getElementById('quoteDetailContent').innerHTML = `
            <div class="space-y-4">
              <div class="flex justify-between items-start">
                <div>
                  <p class="text-[#A8B0C2] text-xs">Devis #${quote.id}</p>
                  <h4 class="text-xl font-bold text-white">${quote.customerName}</h4>
                  <p class="text-[#A8B0C2]">${quote.customerEmail}</p>
                </div>
                <span class="px-3 py-1 rounded-full text-sm ${quote.status === 'pending' ? 'bg-[#F59E0B]/20 text-[#F59E0B]' : 'bg-[#10B981]/20 text-[#10B981]'}">
                  ${quote.status === 'pending' ? 'En attente' : 'Accepté'}
                </span>
              </div>
              
              <div class="p-4 rounded-xl bg-black/20">
                <div class="grid grid-cols-2 gap-4 text-sm">
                  <div>
                    <p class="text-[#A8B0C2] text-xs">Départ</p>
                    <p class="text-white font-medium">${quote.from}</p>
                  </div>
                  <div>
                    <p class="text-[#A8B0C2] text-xs">Arrivée</p>
                    <p class="text-white font-medium">${quote.to}</p>
                  </div>
                  <div>
                    <p class="text-[#A8B0C2] text-xs">Date/Heure</p>
                    <p class="text-white font-medium">${new Date(quote.datetime).toLocaleString('fr-FR')}</p>
                  </div>
                  <div>
                    <p class="text-[#A8B0C2] text-xs">Véhicule</p>
                    <p class="text-white font-medium">${quote.vehicleType}</p>
                  </div>
                </div>
              </div>
              
              <div class="flex justify-between items-center p-4 rounded-xl bg-black/20">
                <span class="text-[#A8B0C2]">Montant total</span>
                <span class="text-2xl font-bold text-[#D6B15E]">${quote.amount}€</span>
              </div>
              
              ${quote.pricingMode === 'deposit' ? `
                <div class="grid grid-cols-2 gap-4">
                  <div class="p-3 rounded-xl bg-[#F59E0B]/10 border border-[#F59E0B]/30">
                    <p class="text-[#F59E0B] text-xs">Acompte</p>
                    <p class="text-white font-bold">${quote.depositAmount}€</p>
                  </div>
                  <div class="p-3 rounded-xl bg-black/20">
                    <p class="text-[#A8B0C2] text-xs">Solde</p>
                    <p class="text-white font-bold">${quote.balanceAmount}€</p>
                  </div>
                </div>
              ` : ''}
              
              <div class="flex gap-3 pt-4">
                <button onclick="app.closeModal('viewQuote')" class="flex-1 px-4 py-2 rounded-xl border border-[rgba(255,255,255,0.12)] hover:bg-white/5 transition-all text-white">
                  Fermer
                </button>
                ${quote.status === 'pending' ? `
                  <button onclick="app.cancelQuote('${quote.id}')" class="px-4 py-2 rounded-xl bg-[#EF4444]/20 text-[#EF4444] hover:bg-[#EF4444]/30 transition-all">
                    <i class="fas fa-times mr-2"></i>Annuler
                  </button>
                ` : ''}
              </div>
            </div>
          `;
          this.showModal('viewQuote');
        } catch (error) {
          this.showToast('Erreur lors du chargement', 'error');
        }
      },

      // ACTIONS CHAUFFEURS
      saveDriver(e) {
        e.preventDefault();
        this.showToast('Chauffeur enregistré (simulation)', 'success');
        this.closeModal('driver');
        this.loadDrivers();
      },

      editDriver(id) {
        document.getElementById('driver-modal-title').textContent = 'Modifier le chauffeur';
        this.showModal('driver');
      },

      toggleDriverStatus(id) {
        this.showToast('Statut modifié (simulation)', 'success');
        this.loadDrivers();
      },

      // NOTIFICATIONS
      toggleNotifications() {
        document.getElementById('notificationPanel').classList.toggle('active');
        if (document.getElementById('notificationPanel').classList.contains('active')) {
          state.unreadCount = 0;
          this.updateNotificationBadge();
        }
      },

      updateNotifications() {
        const list = document.getElementById('notificationsList');
        const count = state.notifications.filter(n => !n.read).length;
        
        document.getElementById('notifCount').textContent = count;
        state.unreadCount = count;
        this.updateNotificationBadge();

        if (list) {
          list.innerHTML = state.notifications.map(n => `
            <div class="notification-item ${n.read ? '' : 'new'}" onclick="app.readNotification(${n.id})">
              <div class="flex justify-between items-start">
                <p class="text-sm font-medium text-white">${n.message}</p>
                ${!n.read ? '<span class="w-2 h-2 bg-[#D6B15E] rounded-full"></span>' : ''}
              </div>
              <p class="text-xs text-[#A8B0C2] mt-1">${n.time}</p>
            </div>
          `).join('');
        }
      },

      updateNotificationBadge() {
        const badge = document.getElementById('notifBadge');
        if (state.unreadCount > 0) {
          badge.classList.remove('hidden');
          badge.textContent = state.unreadCount;
        } else {
          badge.classList.add('hidden');
        }
      },

      readNotification(id) {
        const notif = state.notifications.find(n => n.id === id);
        if (notif) {
          notif.read = true;
          this.updateNotifications();
        }
      },

      markAllRead() {
        state.notifications.forEach(n => n.read = true);
        this.updateNotifications();
      },

      // EXPORT
      exportData(type) {
        this.showToast(`Export ${type} démarré...`, 'info');
        this.closeModal('export');
        
        // Simulation d'export
        setTimeout(() => {
          const data = { type, date: new Date().toISOString(), items: [] };
          const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = `shvip_export_${type}_${new Date().toISOString().split('T')[0]}.json`;
          a.click();
          this.showToast('Export téléchargé', 'success');
        }, 1000);
      },

      // HELPERS
      apiCall(endpoint, options = {}) {
        const url = `${CONFIG.baseUrl}${endpoint}`;
        const defaultOptions = {
          headers: {
            'Authorization': `Bearer ${state.token}`,
            'Content-Type': 'application/json'
          }
        };
        return fetch(url, { ...defaultOptions, ...options });
      },

      showModal(name) {
        const modal = document.getElementById(`modal-${name}`);
        if (modal) modal.classList.add('active');
      },

      closeModal(name) {
        const modal = document.getElementById(`modal-${name}`);
        if (modal) modal.classList.remove('active');
      },

      updatePriceFields() {
        const mode = document.getElementById('pricingMode').value;
        const depositFields = document.getElementById('depositFields');
        if (mode === 'deposit') {
          depositFields.classList.remove('hidden');
        } else {
          depositFields.classList.add('hidden');
        }
      },

      showToast(message, type = 'info') {
        const toast = document.getElementById('toast');
        toast.textContent = message;
        toast.className = `toast ${type} show`;
        setTimeout(() => toast.classList.remove('show'), 3000);
      },

      refreshData() {
        this.loadPageData(state.currentPage);
      }
    };

    // Démarrer
    app.init();
  </script>

  <!-- Reservation Modal -->
  <div id="modal-reservation" class="modal">
    <div class="modal-overlay" onclick="app.closeModal('reservation')"></div>
    <div class="modal-container glass-panel p-6 rounded-2xl w-[min(860px,92vw)]">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-white text-lg font-bold">Nouvelle réservation</h3>
        <button class="text-[#A8B0C2] hover:text-white" onclick="app.closeModal('reservation')"><i class="fas fa-times"></i></button>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-4">
        <input id="resClientName" class="px-4 py-2 rounded-xl bg-white/5 text-white placeholder-[#A8B0C2] outline-none" placeholder="Nom client *" />
        <input id="resClientEmail" class="px-4 py-2 rounded-xl bg-white/5 text-white placeholder-[#A8B0C2] outline-none" placeholder="Email client *" />
        <input id="resClientPhone" class="px-4 py-2 rounded-xl bg-white/5 text-white placeholder-[#A8B0C2] outline-none" placeholder="Téléphone client" />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-4">
        <input id="resPickup" class="px-4 py-2 rounded-xl bg-white/5 text-white placeholder-[#A8B0C2] outline-none" placeholder="Pickup (adresse) *" />
        <input id="resDropoff" class="px-4 py-2 rounded-xl bg-white/5 text-white placeholder-[#A8B0C2] outline-none" placeholder="Dropoff (adresse) *" />
        <input id="resDatetime" type="datetime-local" class="px-4 py-2 rounded-xl bg-white/5 text-white outline-none" />
        <select id="resVehicle" class="px-4 py-2 rounded-xl bg-white/5 text-white outline-none">
          <option value="berline">Berline</option>
          <option value="van">Van</option>
          <option value="van_plus">Van+</option>
        </select>
        <input id="resPrice" type="number" min="1" step="1" class="px-4 py-2 rounded-xl bg-white/5 text-white placeholder-[#A8B0C2] outline-none" placeholder="Prix (€) *" />
        <input id="resNotes" class="px-4 py-2 rounded-xl bg-white/5 text-white placeholder-[#A8B0C2] outline-none" placeholder="Notes (optionnel)" />
      </div>

      <div class="flex justify-end gap-3">
        <button onclick="app.closeModal('reservation')" class="px-4 py-2 rounded-xl bg-white/5 hover:bg-white/10 text-white">Annuler</button>
        <button onclick="app.createReservationFromModal()" class="px-4 py-2 rounded-xl gold-gradient text-black font-semibold">Créer</button>
      </div>
    </div>
  </div>

</body>
</html>