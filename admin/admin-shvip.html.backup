    function escapeHtml(str) {
      return String(str || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>SHVIP — Dashboard Admin Pro</title>
  
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            gold: "#D6B15E",
            gold2: "#B8922A",
            pearl: "#E9ECF2",
            muted: "#A8B0C2",
            success: "#10B981",
            danger: "#EF4444",
            warning: "#F59E0B",
            info: "#3B82F6"
          },
          animation: {
            'fade-in': 'fadeIn 0.5s ease-out',
            'slide-in': 'slideIn 0.3s ease-out',
            'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',
          },
          keyframes: {
            fadeIn: {
              '0%': { opacity: '0', transform: 'translateY(10px)' },
              '100%': { opacity: '1', transform: 'translateY(0)' },
            },
            slideIn: {
              '0%': { transform: 'translateX(-20px)', opacity: '0' },
              '100%': { transform: 'translateX(0)', opacity: '1' },
            }
          }
        }
      }
    };
  </script>
  
  <style>
    body { font-family: 'Inter', sans-serif; background-color: #05070E; color: #E9ECF2; }
    .glass-panel {
      background: rgba(255, 255, 255, 0.03);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }
    .gold-gradient {
      background: linear-gradient(135deg, #D6B15E 0%, #B8922A 100%);
    }
    .custom-scrollbar::-webkit-scrollbar {
      width: 6px;
      height: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
      background: rgba(255,255,255,0.05);
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: rgba(214, 177, 94, 0.5);
      border-radius: 3px;
    }
    .nav-item.active {
      background: rgba(214, 177, 94, 0.15);
      border-left: 3px solid #D6B15E;
      color: #D6B15E;
    }
    .modal {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.9);
      z-index: 50;
      align-items: center;
      justify-content: center;
      backdrop-filter: blur(8px);
    }
    .modal.active {
      display: flex;
    }
    .toast {
      position: fixed;
      bottom: 20px;
      right: 20px;
      padding: 16px 24px;
      border-radius: 12px;
      color: white;
      font-weight: 500;
      z-index: 100;
      transform: translateX(400px);
      transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }
    .toast.show {
      transform: translateX(0);
    }
    .toast.success { background: linear-gradient(135deg, #10B981 0%, #059669 100%); }
    .toast.error { background: linear-gradient(135deg, #EF4444 0%, #DC2626 100%); }
    .toast.warning { background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%); }
    
    .live-dot {
      width: 8px;
      height: 8px;
      background: #10B981;
      border-radius: 50%;
      animation: pulse 2s infinite;
      display: inline-block;
    }
    
    .skeleton {
      background: linear-gradient(90deg, rgba(255,255,255,0.05) 25%, rgba(255,255,255,0.1) 50%, rgba(255,255,255,0.05) 75%);
      background-size: 200% 100%;
      animation: loading 1.5s infinite;
      border-radius: 4px;
    }
    @keyframes loading {
      0% { background-position: 200% 0; }
      100% { background-position: -200% 0; }
    }

    /* Calendar Styles */
    .calendar-grid {
      display: grid;
      grid-template-columns: 60px repeat(7, 1fr);
      gap: 1px;
      background: rgba(255,255,255,0.1);
      border-radius: 12px;
      overflow: hidden;
    }
    .calendar-header {
      background: rgba(214, 177, 94, 0.2);
      padding: 12px;
      text-align: center;
      font-weight: 600;
      font-size: 0.875rem;
    }
    .calendar-time {
      background: rgba(0,0,0,0.3);
      padding: 8px;
      text-align: center;
      font-size: 0.75rem;
      color: #A8B0C2;
    }
    .calendar-cell {
      background: rgba(255,255,255,0.03);
      min-height: 60px;
      position: relative;
      cursor: pointer;
      transition: all 0.2s;
    }
    .calendar-cell:hover {
      background: rgba(214, 177, 94, 0.1);
    }
    .calendar-event {
      position: absolute;
      left: 2px;
      right: 2px;
      border-radius: 4px;
      padding: 2px 4px;
      font-size: 0.7rem;
      overflow: hidden;
      cursor: pointer;
      transition: transform 0.2s;
    }
    .calendar-event:hover {
      transform: scale(1.02);
      z-index: 10;
    }
    .event-reservation { background: linear-gradient(135deg, #10B981 0%, #059669 100%); }
    .event-available { background: rgba(214, 177, 94, 0.3); border: 1px dashed #D6B15E; }
    .event-unavailable { background: rgba(239, 68, 68, 0.3); }
    .event-pending { background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%); }

    /* Notification panel */
    .notification-panel {
      position: fixed;
      top: 80px;
      right: 20px;
      width: 380px;
      max-height: 500px;
      background: rgba(5, 7, 14, 0.95);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 16px;
      padding: 20px;
      z-index: 40;
      transform: translateX(420px);
      transition: transform 0.3s ease;
      backdrop-filter: blur(20px);
    }
    .notification-panel.active {
      transform: translateX(0);
    }
    .notification-item {
      padding: 12px;
      border-radius: 8px;
      margin-bottom: 8px;
      background: rgba(255,255,255,0.05);
      border-left: 3px solid #D6B15E;
      animation: slideIn 0.3s ease;
    }
    .notification-item.new {
      background: rgba(214, 177, 94, 0.1);
    }
  </style>
</head>
<body class="min-h-screen overflow-hidden">

  <!-- Toast Notification -->
  <div id="toast" class="toast"></div>

  <!-- Notification Panel -->
  <div id="notificationPanel" class="notification-panel custom-scrollbar">
    <div class="flex justify-between items-center mb-4">
      <h3 class="font-bold flex items-center gap-2 text-white">
        <i class="fas fa-bell text-[#D6B15E]"></i>
        Notifications
        <span id="notifCount" class="bg-[#D6B15E] text-black text-xs px-2 py-0.5 rounded-full">0</span>
      </h3>
      <button onclick="app.toggleNotifications()" class="text-[#A8B0C2] hover:text-[#E9ECF2]">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div id="notificationsList" class="space-y-2 max-h-96 overflow-y-auto">
      <!-- Notifications injected here -->
    </div>
    <button onclick="app.markAllRead()" class="w-full mt-4 py-2 text-sm text-[#A8B0C2] hover:text-[#D6B15E] transition-colors border-t border-[rgba(255,255,255,0.12)]">
      Tout marquer comme lu
    </button>
  </div>

  <!-- Login Screen -->
  <div id="loginScreen" class="fixed inset-0 bg-[#05070E] z-[60] flex items-center justify-center">
    <div class="w-full max-w-md p-8">
      <div class="text-center mb-8">
        <div class="w-20 h-20 rounded-2xl gold-gradient flex items-center justify-center mx-auto mb-4 shadow-lg shadow-[#D6B15E]/20">
          <i class="fas fa-crown text-black text-3xl"></i>
        </div>
        <h1 class="text-2xl font-bold mb-2">SHVIP Admin</h1>
        <p class="text-[#A8B0C2]">Authentification requise</p>
      </div>
      
      <form id="loginForm" onsubmit="app.login(event)" class="space-y-4">
        <div>
          <label class="block text-xs text-[#A8B0C2] mb-2 uppercase tracking-wider">Token Administrateur</label>
          <input type="password" id="adminToken" required 
                 class="w-full px-4 py-3 rounded-xl bg-black/30 border border-[rgba(255,255,255,0.12)] focus:border-[#D6B15E] focus:outline-none text-white font-mono text-sm"
                 placeholder="shvip_admin_...">
          <p class="text-xs text-[#A8B0C2] mt-2">
            <i class="fas fa-shield-alt mr-1"></i>
            Le token est défini dans les variables d'environnement Netlify (ADMIN_TOKEN)
          </p>
        </div>
        
        <button type="submit" class="w-full py-3 rounded-xl gold-gradient text-black font-bold transition-all hover:shadow-lg hover:shadow-[#D6B15E]/20">
          <i class="fas fa-lock mr-2"></i>Accéder au Dashboard
        </button>
        
        <div id="loginError" class="hidden p-3 rounded-lg bg-[#EF4444]/10 border border-[#EF4444]/30 text-[#EF4444] text-sm text-center">
          Token invalide. Vérifiez vos variables d'environnement Netlify.
        </div>
      </form>
      
      <div class="mt-8 pt-6 border-t border-[rgba(255,255,255,0.12)] text-center">
        <p class="text-xs text-[#A8B0C2]">
          <i class="fas fa-info-circle mr-1"></i>
          Cette page est protégée. Toute tentative d'accès non autorisée est enregistrée.
        </p>
      </div>
    </div>
  </div>

  <!-- Main App (Hidden until login) -->
  <div id="mainApp" class="hidden flex h-screen">
    <!-- Sidebar -->
    <aside class="w-64 bg-black/40 border-r border-[rgba(255,255,255,0.12)] flex flex-col">
      <div class="p-6 border-b border-[rgba(255,255,255,0.12)]">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl gold-gradient flex items-center justify-center">
            <i class="fas fa-crown text-black text-lg"></i>
          </div>
          <div>
            <h1 class="font-bold text-lg tracking-tight">SHVIP</h1>
            <div class="flex items-center gap-1 text-xs text-[#A8B0C2]">
              <span class="live-dot"></span>
              <span>Connecté</span>
            </div>
          </div>
        </div>
      </div>

      <nav class="flex-1 py-6 px-3 space-y-1 overflow-y-auto custom-scrollbar">
        <button onclick="app.navigate('dashboard')" class="nav-item active w-full flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all hover:bg-white/5 text-left">
          <i class="fas fa-chart-line w-5"></i>
          Tableau de bord
        </button>
        <button onclick="app.navigate('calendar')" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all hover:bg-white/5 text-left text-[#A8B0C2] hover:text-[#E9ECF2]">
          <i class="fas fa-calendar-alt w-5"></i>
          Planning Chauffeurs
        </button>
        <button onclick="app.navigate('rides')" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all hover:bg-white/5 text-left text-[#A8B0C2] hover:text-[#E9ECF2]">
          <i class="fas fa-route w-5"></i>
          Courses en direct
        </button>
        <button onclick="app.navigate('reservations')" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all hover:bg-white/5 text-left text-[#A8B0C2] hover:text-[#E9ECF2]">
          <i class="fas fa-clipboard-list w-5"></i>
          Réservations
        </button>
        <button onclick="app.navigate('payments')" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all hover:bg-white/5 text-left text-[#A8B0C2] hover:text-[#E9ECF2]">
          <i class="fab fa-stripe w-5"></i>
          Paiements Stripe
        </button>
        <button onclick="app.navigate('quotes')" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all hover:bg-white/5 text-left text-[#A8B0C2] hover:text-[#E9ECF2]">
          <i class="fas fa-file-invoice-dollar w-5"></i>
          Devis
        </button>
        <button onclick="app.navigate('invoices')" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all hover:bg-white/5 text-left text-[#A8B0C2] hover:text-[#E9ECF2]">
          <i class="fas fa-file-invoice w-5"></i>
          Factures
        </button>
        <button onclick="app.navigate('drivers')" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all hover:bg-white/5 text-left text-[#A8B0C2] hover:text-[#E9ECF2]">
          <i class="fas fa-id-card w-5"></i>
          Chauffeurs
        </button>
        <button onclick="app.navigate('clients')" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all hover:bg-white/5 text-left text-[#A8B0C2] hover:text-[#E9ECF2]">
          <i class="fas fa-users w-5"></i>
          Clients
        </button>
        <button onclick="app.navigate('stats')" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all hover:bg-white/5 text-left text-[#A8B0C2] hover:text-[#E9ECF2]">
          <i class="fas fa-chart-pie w-5"></i>
          Statistiques
        </button>
        <button onclick="app.navigate('settings')" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all hover:bg-white/5 text-left text-[#A8B0C2] hover:text-[#E9ECF2]">
          <i class="fas fa-cog w-5"></i>
          Configuration
        </button>
      </nav>

      <div class="p-4 border-t border-[rgba(255,255,255,0.12)]">
        <div class="flex items-center gap-3 px-3 py-2 rounded-xl bg-[rgba(255,255,255,0.06)]">
          <div class="w-8 h-8 rounded-full bg-[#D6B15E] flex items-center justify-center text-black font-bold text-xs">
            A
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium truncate">Administrateur</p>
            <p class="text-xs text-[#A8B0C2] truncate" id="envIndicator">Production</p>
          </div>
          <button onclick="app.logout()" class="text-[#A8B0C2] hover:text-[#EF4444] transition-colors" title="Déconnexion">
            <i class="fas fa-sign-out-alt"></i>
          </button>
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 overflow-hidden flex flex-col">
      <!-- Header -->
      <header class="h-16 border-b border-[rgba(255,255,255,0.12)] bg-black/20 flex items-center justify-between px-8">
        <div class="flex items-center gap-4">
          <h2 id="pageTitle" class="text-xl font-bold">Tableau de bord</h2>
          <span id="pageSubtitle" class="text-sm text-[#A8B0C2]">Vue d'ensemble</span>
        </div>
        <div class="flex items-center gap-4">
          <div id="apiStatus" class="flex items-center gap-2 text-xs px-3 py-1 rounded-full bg-[#10B981]/20 text-[#10B981]">
            <span class="w-2 h-2 rounded-full bg-[#10B981] animate-pulse"></span>
            API Connectée
          </div>
          
          <!-- Notifications Bell -->
          <button onclick="app.toggleNotifications()" class="relative p-2 rounded-xl hover:bg-white/10 transition-all text-white">
            <i class="fas fa-bell text-lg"></i>
            <span id="notifBadge" class="absolute top-0 right-0 w-5 h-5 bg-[#EF4444] text-white text-xs rounded-full flex items-center justify-center hidden">0</span>
          </button>

          <button onclick="app.showModal('newQuote')" class="px-4 py-2 rounded-lg gold-gradient text-black text-sm font-medium transition-all hover:shadow-lg hover:shadow-[#D6B15E]/20">
            <i class="fas fa-plus mr-2"></i>Nouveau devis
          </button>
        </div>
      </header>

      <!-- Content Area -->
      <div id="content" class="flex-1 overflow-y-auto custom-scrollbar p-8">
        <!-- Dynamic content loaded here -->
      </div>
    </main>
  </div>

  <!-- New Quote Modal -->
  <div id="modal-newQuote" class="modal">
    <div class="bg-[#05070E] border border-[rgba(255,255,255,0.12)] rounded-2xl w-full max-w-2xl p-6 m-4 shadow-2xl max-h-[90vh] overflow-y-auto">
      <div class="flex justify-between items-center mb-6">
        <h3 class="text-xl font-bold text-white">Créer un devis client</h3>
        <button onclick="app.closeModal('newQuote')" class="text-[#A8B0C2] hover:text-[#E9ECF2]">
          <i class="fas fa-times text-xl"></i>
        </button>
      </div>
      
      <form id="quoteForm" onsubmit="app.submitQuote(event)" class="space-y-4">
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs text-[#A8B0C2] mb-1">Email client *</label>
            <input type="email" name="customerEmail" required 
                   class="w-full px-3 py-2 rounded-xl bg-black/30 border border-[rgba(255,255,255,0.12)] focus:border-[#D6B15E] focus:outline-none text-white"
                   placeholder="client@exemple.com">
          </div>
          <div>
            <label class="block text-xs text-[#A8B0C2] mb-1">Nom complet *</label>
            <input type="text" name="customerName" required
                   class="w-full px-3 py-2 rounded-xl bg-black/30 border border-[rgba(255,255,255,0.12)] focus:border-[#D6B15E] focus:outline-none text-white"
                   placeholder="Jean Dupont">
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs text-[#A8B0C2] mb-1">Téléphone</label>
            <input type="tel" name="customerPhone" 
                   class="w-full px-3 py-2 rounded-xl bg-black/30 border border-[rgba(255,255,255,0.12)] focus:border-[#D6B15E] focus:outline-none text-white"
                   placeholder="06 12 34 56 78">
          </div>
          <div>
            <label class="block text-xs text-[#A8B0C2] mb-1">Type de trajet</label>
            <select name="tripType" class="w-full px-3 py-2 rounded-xl bg-black/30 border border-[rgba(255,255,255,0.12)] focus:border-[#D6B15E] focus:outline-none text-white">
              <option value="oneway">Aller simple</option>
              <option value="roundtrip">Aller-retour</option>
              <option value="hourly">Mise à disposition</option>
            </select>
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs text-[#A8B0C2] mb-1">Lieu de prise en charge *</label>
            <input type="text" name="from" required 
                   class="w-full px-3 py-2 rounded-xl bg-black/30 border border-[rgba(255,255,255,0.12)] focus:border-[#D6B15E] focus:outline-none text-white"
                   placeholder="Aéroport CDG, Terminal 2">
          </div>
          <div>
            <label class="block text-xs text-[#A8B0C2] mb-1">Destination *</label>
            <input type="text" name="to" required 
                   class="w-full px-3 py-2 rounded-xl bg-black/30 border border-[rgba(255,255,255,0.12)] focus:border-[#D6B15E] focus:outline-none text-white"
                   placeholder="Paris 8ème, Hotel X">
          </div>
        </div>

        <div class="grid md:grid-cols-3 gap-4">
          <div>
            <label class="block text-xs text-[#A8B0C2] mb-1">Date & Heure *</label>
            <input type="datetime-local" name="datetime" required 
                   class="w-full px-3 py-2 rounded-xl bg-black/30 border border-[rgba(255,255,255,0.12)] focus:border-[#D6B15E] focus:outline-none text-white">
          </div>
          <div>
            <label class="block text-xs text-[#A8B0C2] mb-1">Véhicule</label>
            <select name="vehicleType" class="w-full px-3 py-2 rounded-xl bg-black/30 border border-[rgba(255,255,255,0.12)] focus:border-[#D6B15E] focus:outline-none text-white">
              <option value="berline">Berline Premium</option>
              <option value="van">Van/MPV (7 places)</option>
              <option value="van_plus">Van Luxe (8 places)</option>
            </select>
          </div>
          <div>
            <label class="block text-xs text-[#A8B0C2] mb-1">Passagers</label>
            <select name="passengers" class="w-full px-3 py-2 rounded-xl bg-black/30 border border-[rgba(255,255,255,0.12)] focus:border-[#D6B15E] focus:outline-none text-white">
              ${Array.from({length: 8}, (_, i) => `<option value="${i+1}">${i+1} passager${i > 0 ? 's' : ''}</option>`).join('')}
            </select>
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs text-[#A8B0C2] mb-1">Mode de prix</label>
            <select name="pricingMode" id="pricingMode" onchange="app.updatePriceFields()" 
                    class="w-full px-3 py-2 rounded-xl bg-black/30 border border-[rgba(255,255,255,0.12)] focus:border-[#D6B15E] focus:outline-none text-white">
              <option value="total">Prix total</option>
              <option value="deposit">Acompte + Solde</option>
            </select>
          </div>
          <div>
            <label class="block text-xs text-[#A8B0C2] mb-1">Montant total (€) *</label>
            <input type="number" name="amount" id="totalAmount" required step="0.01" min="0"
                   class="w-full px-3 py-2 rounded-xl bg-black/50 border border-[rgba(255,255,255,0.12)] text-[#D6B15E] font-bold text-lg text-white"
                   placeholder="0.00">
          </div>
        </div>

        <div id="depositFields" class="grid md:grid-cols-2 gap-4 hidden">
          <div>
            <label class="block text-xs text-[#A8B0C2] mb-1">Acompte (€)</label>
            <input type="number" name="depositAmount" id="depositAmount" step="0.01" min="0"
                   class="w-full px-3 py-2 rounded-xl bg-black/30 border border-[rgba(255,255,255,0.12)] focus:border-[#D6B15E] focus:outline-none text-white"
                   placeholder="0.00">
          </div>
          <div>
            <label class="block text-xs text-[#A8B0C2] mb-1">Solde à payer (€)</label>
            <input type="number" name="balanceAmount" id="balanceAmount" step="0.01" min="0" readonly
                   class="w-full px-3 py-2 rounded-xl bg-black/30 border border-[rgba(255,255,255,0.12)] text-[#A8B0C2] text-white"
                   placeholder="Calculé automatiquement">
          </div>
        </div>

        <div>
          <label class="block text-xs text-[#A8B0C2] mb-1">Notes / Commentaires</label>
          <textarea name="notes" rows="3" 
                    class="w-full px-3 py-2 rounded-xl bg-black/30 border border-[rgba(255,255,255,0.12)] focus:border-[#D6B15E] focus:outline-none text-white"
                    placeholder="Sièges bébé, animaux, bagages volumineux, vol numéro..."></textarea>
        </div>

        <div class="p-3 rounded-lg bg-[#10B981]/10 border border-[#10B981]/30">
          <p class="text-xs text-[#10B981]">
            <i class="fas fa-info-circle mr-1"></i>
            Un email professionnel sera envoyé au client avec le PDF du devis et un lien de paiement sécurisé Stripe.
          </p>
        </div>

        <div class="flex gap-3 pt-4">
          <button type="button" onclick="app.closeModal('newQuote')" 
                  class="flex-1 px-4 py-2 rounded-xl border border-[rgba(255,255,255,0.12)] hover:bg-white/5 transition-all text-white">
            Annuler
          </button>
          <button type="submit" id="submitQuoteBtn"
                  class="flex-1 px-4 py-2 rounded-xl gold-gradient text-black font-medium transition-all hover:shadow-lg hover:shadow-[#D6B15E]/20">
            <i class="fas fa-paper-plane mr-2"></i>Créer et envoyer
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- View Quote Modal -->
  <div id="modal-viewQuote" class="modal">
    <div class="bg-[#05070E] border border-[rgba(255,255,255,0.12)] rounded-2xl w-full max-w-2xl p-6 m-4 shadow-2xl max-h-[90vh] overflow-y-auto">
      <div class="flex justify-between items-center mb-6">
        <h3 class="text-xl font-bold text-white">Détail du devis</h3>
        <button onclick="app.closeModal('viewQuote')" class="text-[#A8B0C2] hover:text-[#E9ECF2]">
          <i class="fas fa-times text-xl"></i>
        </button>
      </div>
      <div id="quoteDetailContent" class="space-y-4">
        <!-- Content loaded dynamically -->
      </div>
    </div>
  </div>

  <!-- Driver Modal -->
  <div id="modal-driver" class="modal">
    <div class="bg-[#05070E] border border-[rgba(255,255,255,0.12)] rounded-2xl w-full max-w-lg p-6 m-4 shadow-2xl max-h-[90vh] overflow-y-auto">
      <div class="flex justify-between items-center mb-6">
        <h3 class="text-xl font-bold text-white" id="driver-modal-title">Nouveau chauffeur</h3>
        <button onclick="app.closeModal('driver')" class="text-[#A8B0C2] hover:text-[#E9ECF2]">
          <i class="fas fa-times text-xl"></i>
        </button>
      </div>
      <form id="driverForm" onsubmit="app.saveDriver(event)" class="space-y-4">
        <input type="hidden" id="driver-id">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs text-[#A8B0C2] mb-1">Prénom *</label>
            <input type="text" id="driver-firstname" required 
                   class="w-full px-3 py-2 rounded-xl bg-black/30 border border-[rgba(255,255,255,0.12)] focus:border-[#D6B15E] focus:outline-none text-white">
          </div>
          <div>
            <label class="block text-xs text-[#A8B0C2] mb-1">Nom *</label>
            <input type="text" id="driver-lastname" required 
                   class="w-full px-3 py-2 rounded-xl bg-black/30 border border-[rgba(255,255,255,0.12)] focus:border-[#D6B15E] focus:outline-none text-white">
          </div>
        </div>
        <div>
          <label class="block text-xs text-[#A8B0C2] mb-1">Email *</label>
          <input type="email" id="driver-email" required 
                 class="w-full px-3 py-2 rounded-xl bg-black/30 border border-[rgba(255,255,255,0.12)] focus:border-[#D6B15E] focus:outline-none text-white">
        </div>
        <div>
          <label class="block text-xs text-[#A8B0C2] mb-1">Téléphone *</label>
          <input type="tel" id="driver-phone" required 
                 class="w-full px-3 py-2 rounded-xl bg-black/30 border border-[rgba(255,255,255,0.12)] focus:border-[#D6B15E] focus:outline-none text-white">
        </div>
        <div>
          <label class="block text-xs text-[#A8B0C2] mb-1">Code chauffeur *</label>
          <input type="text" id="driver-code" required 
                 class="w-full px-3 py-2 rounded-xl bg-black/30 border border-[rgba(255,255,255,0.12)] focus:border-[#D6B15E] focus:outline-none uppercase font-mono text-white"
                 placeholder="SH-001">
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs text-[#A8B0C2] mb-1">Véhicule</label>
            <select id="driver-vehicle" class="w-full px-3 py-2 rounded-xl bg-black/30 border border-[rgba(255,255,255,0.12)] focus:border-[#D6B15E] focus:outline-none text-white">
              <option value="berline">Berline Premium</option>
              <option value="van">Van/MPV</option>
              <option value="van_plus">Van Luxe</option>
            </select>
          </div>
          <div>
            <label class="block text-xs text-[#A8B0C2] mb-1">Commission (%)</label>
            <input type="number" id="driver-commission" min="0" max="100" value="20" 
                   class="w-full px-3 py-2 rounded-xl bg-black/30 border border-[rgba(255,255,255,0.12)] focus:border-[#D6B15E] focus:outline-none text-white">
          </div>
        </div>
        
        <!-- Availability -->
        <div class="border-t border-[rgba(255,255,255,0.12)] pt-4">
          <label class="block text-xs text-[#A8B0C2] mb-3">Disponibilités hebdomadaires</label>
          <div class="grid grid-cols-7 gap-2 text-center text-xs" id="availabilityGrid">
            ${['Lun','Mar','Mer','Jeu','Ven','Sam','Dim'].map((day, i) => `
              <div class="space-y-2">
                <div class="text-[#A8B0C2] font-medium">${day}</div>
                <button type="button" class="w-full py-2 rounded-lg bg-[#10B981]/20 text-[#10B981] hover:bg-[#10B981]/30 transition-all availability-toggle active" data-day="${i}">
                  <i class="fas fa-check"></i>
                </button>
                <select class="w-full text-xs bg-black/30 border border-[rgba(255,255,255,0.12)] rounded px-1 py-1 text-white" data-day-start="${i}">
                  <option value="06:00">06h</option>
                  <option value="08:00" selected>08h</option>
                  <option value="10:00">10h</option>
                </select>
                <select class="w-full text-xs bg-black/30 border border-[rgba(255,255,255,0.12)] rounded px-1 py-1 text-white" data-day-end="${i}">
                  <option value="18:00">18h</option>
                  <option value="20:00" selected>20h</option>
                  <option value="22:00">22h</option>
                </select>
              </div>
            `).join('')}
          </div>
        </div>

        <div class="flex gap-3 pt-4">
          <button type="button" onclick="app.closeModal('driver')" 
                  class="flex-1 px-4 py-2 rounded-xl border border-[rgba(255,255,255,0.12)] hover:bg-white/5 transition-all text-white">
            Annuler
          </button>
          <button type="submit" 
                  class="flex-1 px-4 py-2 rounded-xl gold-gradient text-black font-medium transition-all">
            Enregistrer
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Export Modal -->
  <div id="modal-export" class="modal">
    <div class="bg-[#05070E] border border-[rgba(255,255,255,0.12)] rounded-2xl w-full max-w-md p-6 m-4 shadow-2xl">
      <div class="flex justify-between items-center mb-6">
        <h3 class="text-xl font-bold text-white">Exporter les données</h3>
        <button onclick="app.closeModal('export')" class="text-[#A8B0C2] hover:text-[#E9ECF2]">
          <i class="fas fa-times text-xl"></i>
        </button>
      </div>
      
      <div class="space-y-4">
        <div class="p-4 rounded-xl bg-black/20 cursor-pointer hover:bg-white/5 transition-all" onclick="app.exportData('payments')">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-[#10B981]/20 flex items-center justify-center text-[#10B981]">
              <i class="fas fa-credit-card"></i>
            </div>
            <div>
              <div class="font-medium text-white">Paiements</div>
              <div class="text-xs text-[#A8B0C2]">Export CSV des transactions Stripe</div>
            </div>
          </div>
        </div>

        <div class="p-4 rounded-xl bg-black/20 cursor-pointer hover:bg-white/5 transition-all" onclick="app.exportData('quotes')">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-[#F59E0B]/20 flex items-center justify-center text-[#F59E0B]">
              <i class="fas fa-file-invoice-dollar"></i>
            </div>
            <div>
              <div class="font-medium text-white">Devis</div>
              <div class="text-xs text-[#A8B0C2]">Export CSV de tous les devis</div>
            </div>
          </div>
        </div>

        <div class="p-4 rounded-xl bg-black/20 cursor-pointer hover:bg-white/5 transition-all" onclick="app.exportData('invoices')">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-blue-500/20 flex items-center justify-center text-blue-400">
              <i class="fas fa-file-invoice"></i>
            </div>
            <div>
              <div class="font-medium text-white">Factures</div>
              <div class="text-xs text-[#A8B0C2]">Export CSV des factures</div>
            </div>
          </div>
        </div>

        <div class="p-4 rounded-xl bg-black/20 cursor-pointer hover:bg-white/5 transition-all" onclick="app.exportData('full')">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-[#D6B15E]/20 flex items-center justify-center text-[#D6B15E]">
              <i class="fas fa-database"></i>
            </div>
            <div>
              <div class="font-medium text-white">Export complet</div>
              <div class="text-xs text-[#A8B0C2]">Backup JSON de toutes les données</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Configuration
    const CONFIG = {
      get baseUrl() {
        const hostname = window.location.hostname;
        if (hostname.includes('localhost') || hostname.includes('127.0.0.1')) {
          return 'http://localhost:8888/.netlify/functions';
        }
        return `https://${hostname}/.netlify/functions`;
      }
    };

    // Application State
    const state = {
      token: null,
      currentPage: 'dashboard',
      currentQuote: null,
      currentDriver: null,
      notifications: [],
      payments: [],
      quotes: [],
      invoices: [],
      reservations: [],
      drivers: [],
      rides: [],
      stats: null,
      currentWeekOffset: 0,
      unreadCount: 0
    };

    const app = {
      init() {
        const savedToken = sessionStorage.getItem('shvip_admin_token');
        if (savedToken) {
          this.verifyToken(savedToken);
        }
        this.setupDepositCalculation();
        this.setupAvailabilityToggles();
        this.startNotificationPolling();
      },

      setupDepositCalculation() {
        document.addEventListener('input', (e) => {
          if (e.target.id === 'depositAmount' || e.target.id === 'totalAmount') {
            const total = parseFloat(document.getElementById('totalAmount')?.value) || 0;
            const deposit = parseFloat(document.getElementById('depositAmount')?.value) || 0;
            const balanceInput = document.getElementById('balanceAmount');
            if (balanceInput) {
              balanceInput.value = (total - deposit).toFixed(2);
            }
          }
        });
      },

      setupAvailabilityToggles() {
        document.addEventListener('click', (e) => {
          if (e.target.closest('.availability-toggle')) {
            const btn = e.target.closest('.availability-toggle');
            btn.classList.toggle('active');
            btn.classList.toggle('bg-[#10B981]/20');
            btn.classList.toggle('text-[#10B981]');
            btn.classList.toggle('bg-[#EF4444]/20');
            btn.classList.toggle('text-[#EF4444]');
            btn.innerHTML = btn.classList.contains('active') ? '<i class="fas fa-check"></i>' : '<i class="fas fa-times"></i>';
          }
        });
      },

      startNotificationPolling() {
        // Simuler des notifications en temps réel
        setInterval(() => {
          this.checkNewNotifications();
        }, 30000);
      },

      async checkNewNotifications() {
        // Ici vous feriez un appel API pour vérifier les nouvelles notifications
        // Pour l'instant, on simule
        if (Math.random() > 0.9 && state.token) {
          const newNotif = {
            id: Date.now(),
            type: 'payment',
            message: `Nouveau paiement reçu`,
            time: 'À l\'instant',
            read: false
          };
          state.notifications.unshift(newNotif);
          this.updateNotifications();
          this.showToast('Nouvelle notification', 'info');
        }
      },

      // AUTHENTIFICATION
      login(e) {
        e.preventDefault();
        const token = document.getElementById('adminToken').value.trim();
        const errorDiv = document.getElementById('loginError');
        
        if (!token) {
          errorDiv.classList.remove('hidden');
          return;
        }
        this.verifyToken(token);
      },

      async verifyToken(token) {
        const errorDiv = document.getElementById('loginError');
        try {
          const response = await fetch(`${CONFIG.baseUrl}/admin-list-payments?limit=1`, {
            headers: { 'Authorization': `Bearer ${token}` }
          });

          if (response.ok) {
            state.token = token;
            sessionStorage.setItem('shvip_admin_token', token);
            document.getElementById('loginScreen').classList.add('hidden');
            document.getElementById('mainApp').classList.remove('hidden');
            document.getElementById('mainApp').classList.add('flex');
            this.showToast('Authentification réussie', 'success');
            this.navigate('dashboard');
          } else {
            errorDiv.classList.remove('hidden');
            sessionStorage.removeItem('shvip_admin_token');
          }
        } catch (error) {
          errorDiv.textContent = 'Erreur de connexion au serveur.';
          errorDiv.classList.remove('hidden');
        }
      },

      logout() {
        state.token = null;
        sessionStorage.removeItem('shvip_admin_token');
        location.reload();
      },

      // NAVIGATION
      navigate(page) {
        state.currentPage = page;
        document.querySelectorAll('.nav-item').forEach(el => {
          el.classList.remove('active');
          el.classList.add('text-[#A8B0C2]');
        });
        
        const activeBtn = Array.from(document.querySelectorAll('.nav-item')).find(el => 
          el.getAttribute('onclick')?.includes(`'${page}'`)
        );
        if (activeBtn) {
          activeBtn.classList.add('active');
          activeBtn.classList.remove('text-[#A8B0C2]');
        }
        
        const titles = {
          dashboard: ['Tableau de bord', 'Vue d\'ensemble temps réel'],
          calendar: ['Planning Chauffeurs', 'Gestion des disponibilités'],
          rides: ['Courses en direct', 'Suivi temps réel'],
          payments: ['Paiements Stripe', 'Transactions en ligne'],
          quotes: ['Devis', 'Propositions tarifaires'],
          invoices: ['Factures', 'Facturation clients'],
          drivers: ['Chauffeurs', 'Gestion des prestataires'],
          clients: ['Clients', 'Base de données clients'],
          stats: ['Statistiques', 'Analytics et rapports'],
          settings: ['Configuration', 'Paramètres système']
        };
        
        document.getElementById('pageTitle').textContent = titles[page][0];
        document.getElementById('pageSubtitle').textContent = titles[page][1];
        
        this.loadPageData(page);
      },

      // CHARGEMENT DES PAGES
      async loadPageData(page) {
        const content = document.getElementById('content');
        content.innerHTML = '<div class="flex items-center justify-center h-64"><div class="skeleton w-12 h-12 rounded-full"></div></div>';
        
        try {
          switch(page) {
            case 'dashboard':
              await this.loadDashboard();
              break;
            case 'calendar':
              await this.loadCalendar();
              break;
            case 'rides':
              await this.loadRides();
              break;
            case 'reservations':
              await this.loadReservations();
              break;
            case 'payments':
              await this.loadPayments();
              break;
            case 'quotes':
              await this.loadQuotes();
              break;
            case 'invoices':
              await this.loadInvoices();
              break;
            case 'drivers':
              await this.loadDrivers();
              break;
            case 'clients':
              await this.loadClients();
              break;
            case 'stats':
              await this.loadStats();
              break;
            case 'settings':
              await this.loadSettings();
              break;
            default:
              content.innerHTML = '<div class="text-center text-[#A8B0C2]">Page en construction</div>';
          }
        } catch (error) {
          content.innerHTML = `
            <div class="text-center py-12">
              <i class="fas fa-exclamation-triangle text-4xl text-[#EF4444] mb-4"></i>
              <h3 class="text-xl font-bold text-white mb-2">Erreur de chargement</h3>
              <p class="text-[#A8B0C2] mb-4">${error.message}</p>
              <button onclick="app.loadPageData('${page}')" class="px-4 py-2 rounded-lg gold-gradient text-black">
                <i class="fas fa-sync mr-2"></i>Réessayer
              </button>
            </div>
          `;
        }
      },

      // DASHBOARD
      async loadDashboard() {
        const [paymentsRes, quotesRes, statsRes] = await Promise.all([
          this.apiCall('/admin-list-payments?limit=5'),
          this.apiCall('/admin-list-quotes?limit=5'),
          this.apiCall('/admin-stats').catch(() => null)
        ]);

        const payments = await paymentsRes.json().catch(() => ({ payments: [] }));
        const quotes = await quotesRes.json().catch(() => ({ quotes: [] }));
        const stats = statsRes ? await statsRes.json().catch(() => null) : null;

        const totalRevenue = payments.payments?.reduce((sum, p) => sum + (p.amount || 0), 0) || 0;
        const pendingQuotes = quotes.quotes?.filter(q => q.status === 'pending').length || 0;
        const conversionRate = quotes.quotes?.length ? Math.round((quotes.quotes.filter(q => q.status === 'accepted').length / quotes.quotes.length) * 100) : 0;

        document.getElementById('content').innerHTML = `
          <div class="grid md:grid-cols-4 gap-6 mb-8 animate-fade-in">
            <div class="glass-panel rounded-2xl p-6">
              <div class="flex justify-between items-start mb-4">
                <div>
                  <p class="text-[#A8B0C2] text-sm">Chiffre d'affaires</p>
                  <h3 class="text-3xl font-bold text-[#D6B15E] mt-1">${(totalRevenue / 100).toFixed(2)}€</h3>
                </div>
                <div class="w-12 h-12 rounded-xl gold-gradient flex items-center justify-center text-black">
                  <i class="fas fa-euro-sign text-xl"></i>
                </div>
              </div>
              <div class="flex items-center gap-2 text-xs">
                <span class="text-[#10B981]"><i class="fas fa-arrow-up"></i> 12%</span>
                <span class="text-[#A8B0C2]">vs mois dernier</span>
              </div>
            </div>
            
            <div class="glass-panel rounded-2xl p-6">
              <div class="flex justify-between items-start mb-4">
                <div>
                  <p class="text-[#A8B0C2] text-sm">Transactions</p>
                  <h3 class="text-3xl font-bold mt-1 text-white">${payments.payments?.length || 0}</h3>
                </div>
                <div class="w-12 h-12 rounded-xl bg-blue-500/20 flex items-center justify-center text-blue-400">
                  <i class="fas fa-credit-card text-xl"></i>
                </div>
              </div>
            </div>
            
            <div class="glass-panel rounded-2xl p-6">
              <div class="flex justify-between items-start mb-4">
                <div>
                  <p class="text-[#A8B0C2] text-sm">Devis en attente</p>
                  <h3 class="text-3xl font-bold mt-1 text-[#F59E0B]">${pendingQuotes}</h3>
                </div>
                <div class="w-12 h-12 rounded-xl bg-[#F59E0B]/20 flex items-center justify-center text-[#F59E0B]">
                  <i class="fas fa-file-invoice-dollar text-xl"></i>
                </div>
              </div>
            </div>
            
            <div class="glass-panel rounded-2xl p-6">
              <div class="flex justify-between items-start mb-4">
                <div>
                  <p class="text-[#A8B0C2] text-sm">Taux conversion</p>
                  <h3 class="text-3xl font-bold mt-1 text-[#10B981]">${conversionRate}%</h3>
                </div>
                <div class="w-12 h-12 rounded-xl bg-[#10B981]/20 flex items-center justify-center text-[#10B981]">
                  <i class="fas fa-chart-line text-xl"></i>
                </div>
              </div>
            </div>
          </div>

          <div class="grid lg:grid-cols-3 gap-6">
            <div class="lg:col-span-2 glass-panel rounded-2xl p-6">
              <div class="flex justify-between items-center mb-4">
                <h3 class="font-bold flex items-center gap-2 text-white">
                  <i class="fas fa-credit-card text-[#D6B15E]"></i>
                  Derniers paiements
                </h3>
                <button onclick="app.navigate('payments')" class="text-xs text-[#D6B15E] hover:underline">Voir tout →</button>
              </div>
              <div class="space-y-3">
                ${(payments.payments || []).slice(0, 5).map(p => `
                  <div class="flex items-center justify-between p-3 rounded-xl bg-black/20 hover:bg-white/5 transition-all cursor-pointer">
                    <div class="flex items-center gap-3">
                      <div class="w-10 h-10 rounded-full bg-[#10B981]/20 flex items-center justify-center text-[#10B981]">
                        <i class="fas fa-check"></i>
                      </div>
                      <div>
                        <div class="font-medium text-white">${p.customerEmail || 'Client'}</div>
                        <div class="text-xs text-[#A8B0C2]">${new Date(p.created).toLocaleString('fr-FR')}</div>
                      </div>
                    </div>
                    <div class="text-right">
                      <div class="font-bold text-[#D6B15E]">${(p.amount / 100).toFixed(2)}€</div>
                      <span class="text-xs px-2 py-0.5 rounded bg-[#10B981]/20 text-[#10B981]">${p.status}</span>
                    </div>
                  </div>
                `).join('') || '<div class="text-center text-[#A8B0C2] py-4">Aucun paiement récent</div>'}
              </div>
            </div>

            <div class="glass-panel rounded-2xl p-6">
              <div class="flex justify-between items-center mb-4">
                <h3 class="font-bold flex items-center gap-2 text-white">
                  <i class="fas fa-bell text-[#D6B15E]"></i>
                  Activité récente
                </h3>
              </div>
              <div class="space-y-3">
                ${state.notifications.slice(0, 5).map(n => `
                  <div class="flex items-start gap-3 p-3 rounded-lg ${n.read ? 'bg-black/20' : 'bg-[#D6B15E]/10 border border-[#D6B15E]/20'}">
                    <div class="w-8 h-8 rounded-full ${n.type === 'payment' ? 'bg-[#10B981]/20 text-[#10B981]' : 'bg-[#F59E0B]/20 text-[#F59E0B]'} flex items-center justify-center flex-shrink-0">
                      <i class="fas ${n.type === 'payment' ? 'fa-credit-card' : 'fa-info'} text-xs"></i>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-medium text-white truncate">${n.message}</p>
                      <p class="text-xs text-[#A8B0C2]">${n.time}</p>
                    </div>
                    ${!n.read ? '<span class="w-2 h-2 bg-[#D6B15E] rounded-full flex-shrink-0 mt-1"></span>' : ''}
                  </div>
                `).join('') || '<div class="text-center text-[#A8B0C2] py-4">Aucune notification</div>'}
              </div>
            </div>
          </div>
        `;
      },

      // CALENDRIER
      async loadCalendar() {
        const weekDays = ['Dimanche', 'Lundi', 'Mardi', 'Mercredi', 'Jeudi', 'Vendredi', 'Samedi'];
        const today = new Date();
        const currentWeek = this.getWeekDates(state.currentWeekOffset);
        
        // Simuler des données de réservations pour le calendrier
        const mockReservations = [
          { day: 1, hour: 10, client: 'Jean Dupont', from: 'CDG', to: 'Paris', status: 'confirmed' },
          { day: 2, hour: 14, client: 'Marie Martin', from: 'Orly', to: 'Disney', status: 'pending' },
          { day: 3, hour: 9, client: 'Pierre Bernard', from: 'Gare Lyon', to: 'Versailles', status: 'confirmed' },
        ];

        document.getElementById('content').innerHTML = `
          <div class="glass-panel rounded-2xl p-6 animate-fade-in">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6">
              <div>
                <h3 class="font-bold text-xl text-white">Planning hebdomadaire</h3>
                <p class="text-sm text-[#A8B0C2]">Semaine du ${currentWeek[0].toLocaleDateString('fr-FR')} au ${currentWeek[6].toLocaleDateString('fr-FR')}</p>
              </div>
              <div class="flex items-center gap-3">
                <button onclick="app.changeWeek(-1)" class="p-2 rounded-lg hover:bg-white/10 transition-all border border-[rgba(255,255,255,0.12)] text-white">
                  <i class="fas fa-chevron-left"></i>
                </button>
                <button onclick="app.changeWeek(0)" class="px-4 py-2 rounded-lg bg-[#D6B15E]/20 text-[#D6B15E] text-sm font-medium hover:bg-[#D6B15E]/30 transition-all">
                  Aujourd'hui
                </button>
                <button onclick="app.changeWeek(1)" class="p-2 rounded-lg hover:bg-white/10 transition-all border border-[rgba(255,255,255,0.12)] text-white">
                  <i class="fas fa-chevron-right"></i>
                </button>
              </div>
            </div>

            <div class="mb-4 flex flex-wrap gap-2">
              <span class="flex items-center gap-2 text-xs px-3 py-1 rounded-full bg-[#10B981]/20 text-[#10B981]">
                <span class="w-2 h-2 rounded-full bg-[#10B981]"></span> Confirmé
              </span>
              <span class="flex items-center gap-2 text-xs px-3 py-1 rounded-full bg-[#F59E0B]/20 text-[#F59E0B]">
                <span class="w-2 h-2 rounded-full bg-[#F59E0B]"></span> En attente
              </span>
              <span class="flex items-center gap-2 text-xs px-3 py-1 rounded-full bg-[#EF4444]/20 text-[#EF4444]">
                <span class="w-2 h-2 rounded-full bg-[#EF4444]"></span> Indisponible
              </span>
            </div>

            <div class="overflow-x-auto">
              <div class="min-w-[800px]">
                <div class="grid grid-cols-8 gap-1 mb-2">
                  <div class="text-center text-xs text-[#A8B0C2] py-2">Heure</div>
                  ${currentWeek.map((date, i) => `
                    <div class="text-center py-2 ${date.toDateString() === today.toDateString() ? 'bg-[#D6B15E]/20 rounded-lg' : ''}">
                      <div class="text-xs text-[#A8B0C2]">${weekDays[date.getDay()]}</div>
                      <div class="font-bold ${date.toDateString() === today.toDateString() ? 'text-[#D6B15E]' : 'text-white'}">${date.getDate()}</div>
                    </div>
                  `).join('')}
                </div>
                
                ${Array.from({length: 17}, (_, i) => i + 6).map(hour => `
                  <div class="grid grid-cols-8 gap-1 mb-1">
                    <div class="text-center text-xs text-[#A8B0C2] py-3 bg-black/20 rounded">${hour}:00</div>
                    ${currentWeek.map((date, dayIndex) => {
                      const reservation = mockReservations.find(r => r.day === dayIndex && r.hour === hour);
                      const isPast = date < today && date.toDateString() !== today.toDateString();
                      const statusClass = reservation ? (reservation.status === 'confirmed' ? 'bg-[#10B981]/30 border-[#10B981]' : 'bg-[#F59E0B]/30 border-[#F59E0B]') : '';
                      
                      return `
                        <div class="py-1 px-1 min-h-[60px] rounded border border-[rgba(255,255,255,0.08)] ${isPast ? 'opacity-50' : 'hover:bg-white/5 cursor-pointer'} relative group bg-black/20 ${statusClass}">
                          ${reservation ? `
                            <div class="text-xs p-1 rounded text-white">
                              <div class="font-semibold truncate">${reservation.client}</div>
                              <div class="text-[10px] opacity-75">${reservation.from}→${reservation.to}</div>
                            </div>
                          ` : ''}
                          ${!reservation && !isPast ? `
                            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                              <i class="fas fa-plus text-[#D6B15E]/50"></i>
                            </div>
                          ` : ''}
                        </div>
                      `;
                    }).join('')}
                  </div>
                `).join('')}
              </div>
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-6 mt-6">
            <div class="glass-panel rounded-2xl p-6">
              <h3 class="font-bold mb-4 text-white">Chauffeurs disponibles</h3>
              <div class="space-y-3">
                ${[
                  { name: 'Jean Dupont', status: 'available', vehicle: 'Berline', location: 'Paris Centre' },
                  { name: 'Marie Martin', status: 'busy', vehicle: 'Van', location: 'En course' },
                  { name: 'Pierre Bernard', status: 'offline', vehicle: 'Van Luxe', location: 'Indisponible' }
                ].map(d => `
                  <div class="flex items-center justify-between p-3 rounded-xl bg-black/20">
                    <div class="flex items-center gap-3">
                      <div class="relative">
                        <div class="w-10 h-10 rounded-full bg-[#D6B15E] flex items-center justify-center text-black font-bold">
                          ${d.name.charAt(0)}
                        </div>
                        <span class="absolute bottom-0 right-0 w-3 h-3 rounded-full border-2 border-[#05070E] ${d.status === 'available' ? 'bg-[#10B981]' : d.status === 'busy' ? 'bg-[#F59E0B]' : 'bg-[#EF4444]'}"></span>
                      </div>
                      <div>
                        <p class="font-medium text-white text-sm">${d.name}</p>
                        <p class="text-xs text-[#A8B0C2]">${d.vehicle} • ${d.location}</p>
                      </div>
                    </div>
                    <span class="text-xs px-2 py-1 rounded ${d.status === 'available' ? 'bg-[#10B981]/20 text-[#10B981]' : d.status === 'busy' ? 'bg-[#F59E0B]/20 text-[#F59E0B]' : 'bg-[#EF4444]/20 text-[#EF4444]'}">
                      ${d.status === 'available' ? 'Disponible' : d.status === 'busy' ? 'En course' : 'Hors ligne'}
                    </span>
                  </div>
                `).join('')}
              </div>
            </div>

            <div class="glass-panel rounded-2xl p-6">
              <h3 class="font-bold mb-4 text-white">Statistiques de la semaine</h3>
              <div class="space-y-4">
                <div class="flex justify-between items-center p-3 rounded-xl bg-black/20">
                  <span class="text-[#A8B0C2]">Courses programmées</span>
                  <span class="font-bold text-xl text-white">12</span>
                </div>
                <div class="flex justify-between items-center p-3 rounded-xl bg-black/20">
                  <span class="text-[#A8B0C2]">Chiffre d'affaires prévu</span>
                  <span class="font-bold text-xl text-[#D6B15E]">1,240€</span>
                </div>
                <div class="flex justify-between items-center p-3 rounded-xl bg-black/20">
                  <span class="text-[#A8B0C2]">Heures réservées</span>
                  <span class="font-bold text-xl text-white">24h</span>
                </div>
              </div>
            </div>
          </div>
        `;
      },

      changeWeek(offset) {
        state.currentWeekOffset += offset;
        if (offset === 0) state.currentWeekOffset = 0;
        this.loadCalendar();
      },

      getWeekDates(offset) {
        const today = new Date();
        const startOfWeek = new Date(today);
        startOfWeek.setDate(today.getDate() - today.getDay() + (offset * 7));
        
        return Array.from({length: 7}, (_, i) => {
          const date = new Date(startOfWeek);
          date.setDate(startOfWeek.getDate() + i);
          return date;
        });
      },

      // COURSES EN DIRECT
      async loadRides() {
        // Simuler des courses en temps réel
        const mockRides = [
          { id: 'RIDE-001', client: 'Jean Dupont', driver: 'Marie Martin', from: 'CDG Terminal 2', to: 'Paris 8ème', status: 'in_progress', progress: 65, eta: '12 min', price: 85 },
          { id: 'RIDE-002', client: 'Sophie Laurent', driver: 'Jean Martin', from: 'Gare de Lyon', to: 'Orly Sud', status: 'pending', progress: 0, eta: 'En attente', price: 120 },
          { id: 'RIDE-003', client: 'Pierre Bernard', driver: 'Lucas Petit', from: 'Disneyland', to: 'Paris Centre', status: 'completed', progress: 100, eta: 'Terminé', price: 95 },
        ];

        document.getElementById('content').innerHTML = `
          <div class="space-y-6 animate-fade-in">
            <div class="grid md:grid-cols-4 gap-4">
              <div class="glass-panel rounded-2xl p-4 text-center">
                <div class="text-3xl font-bold text-[#10B981]">3</div>
                <div class="text-xs text-[#A8B0C2]">En cours</div>
              </div>
              <div class="glass-panel rounded-2xl p-4 text-center">
                <div class="text-3xl font-bold text-[#F59E0B]">1</div>
                <div class="text-xs text-[#A8B0C2]">En attente</div>
              </div>
              <div class="glass-panel rounded-2xl p-4 text-center">
                <div class="text-3xl font-bold text-[#D6B15E]">12</div>
                <div class="text-xs text-[#A8B0C2]">Aujourd'hui</div>
              </div>
              <div class="glass-panel rounded-2xl p-4 text-center">
                <div class="text-3xl font-bold text-white">1,240€</div>
                <div class="text-xs text-[#A8B0C2]">CA du jour</div>
              </div>
            </div>

            <div class="glass-panel rounded-2xl p-6">
              <div class="flex justify-between items-center mb-6">
                <h3 class="font-bold text-xl text-white">Courses en temps réel</h3>
                <div class="flex items-center gap-2 text-xs text-[#10B981]">
                  <span class="w-2 h-2 rounded-full bg-[#10B981] animate-pulse"></span>
                  Live
                </div>
              </div>

              <div class="space-y-4">
                ${mockRides.map(ride => `
                  <div class="bg-black/20 rounded-xl p-4 border border-[rgba(255,255,255,0.08)]">
                    <div class="flex justify-between items-start mb-3">
                      <div>
                        <div class="flex items-center gap-2">
                          <span class="font-mono text-[#D6B15E] text-sm">${ride.id}</span>
                          <span class="px-2 py-0.5 rounded text-xs ${ride.status === 'in_progress' ? 'bg-[#10B981]/20 text-[#10B981]' : ride.status === 'pending' ? 'bg-[#F59E0B]/20 text-[#F59E0B]' : 'bg-[#A8B0C2]/20 text-[#A8B0C2]'}">
                            ${ride.status === 'in_progress' ? 'En cours' : ride.status === 'pending' ? 'En attente' : 'Terminée'}
                          </span>
                        </div>
                        <h4 class="font-semibold text-white mt-1">${ride.client}</h4>
                      </div>
                      <div class="text-right">
                        <div class="font-bold text-[#D6B15E]">${ride.price}€</div>
                        <div class="text-xs text-[#A8B0C2]">${ride.eta}</div>
                      </div>
                    </div>

                    <div class="flex items-center gap-4 mb-3">
                      <div class="flex-1">
                        <div class="flex items-center gap-2 text-sm text-[#A8B0C2] mb-1">
                          <i class="fas fa-map-marker-alt text-[#10B981]"></i>
                          <span>${ride.from}</span>
                        </div>
                        <div class="flex items-center gap-2 text-sm text-[#A8B0C2]">
                          <i class="fas fa-flag-checkered text-[#EF4444]"></i>
                          <span>${ride.to}</span>
                        </div>
                      </div>
                      <div class="text-center">
                        <div class="w-10 h-10 rounded-full bg-[#D6B15E]/20 flex items-center justify-center text-[#D6B15E]">
                          <i class="fas fa-user"></i>
                        </div>
                        <div class="text-xs text-[#A8B0C2] mt-1">${ride.driver}</div>
                      </div>
                    </div>

                    ${ride.status === 'in_progress' ? `
                      <div class="mt-3">
                        <div class="flex justify-between text-xs text-[#A8B0C2] mb-1">
                          <span>Progression</span>
                          <span>${ride.progress}%</span>
                        </div>
                        <div class="h-2 bg-black/40 rounded-full overflow-hidden">
                          <div class="h-full bg-gradient-to-r from-[#D6B15E] to-[#10B981] rounded-full transition-all duration-500" style="width: ${ride.progress}%"></div>
                        </div>
                      </div>
                    ` : ''}

                    <div class="flex gap-2 mt-3 pt-3 border-t border-[rgba(255,255,255,0.08)]">
                      ${ride.status === 'pending' ? `
                        <button class="flex-1 py-2 rounded-lg bg-[#10B981]/20 text-[#10B981] text-sm hover:bg-[#10B981]/30 transition-all">
                          <i class="fas fa-play mr-1"></i> Démarrer
                        </button>
                      ` : ride.status === 'in_progress' ? `
                        <button class="flex-1 py-2 rounded-lg bg-[#F59E0B]/20 text-[#F59E0B] text-sm hover:bg-[#F59E0B]/30 transition-all">
                          <i class="fas fa-phone mr-1"></i> Appeler
                        </button>
                        <button class="flex-1 py-2 rounded-lg bg-[#10B981]/20 text-[#10B981] text-sm hover:bg-[#10B981]/30 transition-all">
                          <i class="fas fa-check mr-1"></i> Terminer
                        </button>
                      ` : `
                        <button class="flex-1 py-2 rounded-lg bg-white/5 text-white text-sm hover:bg-white/10 transition-all">
                          <i class="fas fa-eye mr-1"></i> Détails
                        </button>
                      `}
                    </div>
                  </div>
                `).join('')}
              </div>
            </div>
          </div>
        `;
      },

      // PAIEMENTS
            async loadReservations() {
        const content = document.getElementById('content');
        content.innerHTML = `
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 animate-fade-in">
            <div class="glass-panel p-6 rounded-2xl lg:col-span-2">
              <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-4">
                <div>
                  <h2 class="text-xl font-bold text-white">Réservations</h2>
                  <p class="text-sm text-[#A8B0C2]">Demandes + réservations confirmées (Supabase)</p>
                </div>
                <div class="flex gap-3">
                  <button onclick="app.refreshReservations()" class="px-4 py-2 rounded-xl bg-white/5 hover:bg-white/10 text-white text-sm">
                    <i class="fas fa-rotate mr-2"></i>Actualiser
                  </button>
                  <button onclick="app.showModal('reservation')" class="px-4 py-2 rounded-xl gold-gradient text-black text-sm font-semibold">
                    <i class="fas fa-plus mr-2"></i>Nouvelle réservation
                  </button>
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-4">
                <input id="resQ" class="px-4 py-2 rounded-xl bg-white/5 text-white placeholder-[#A8B0C2] outline-none"
                       placeholder="Filtrer (nom/email/pickup/dropoff)..." />
                <select id="resStatus" class="px-4 py-2 rounded-xl bg-white/5 text-white outline-none">
                  <option value="">Statut : Tous</option>
                  <option value="pending">pending</option>
                  <option value="confirmed">confirmed</option>
                  <option value="completed">completed</option>
                  <option value="cancelled">cancelled</option>
                </select>
                <select id="resPay" class="px-4 py-2 rounded-xl bg-white/5 text-white outline-none">
                  <option value="">Paiement : Tous</option>
                  <option value="unpaid">unpaid</option>
                  <option value="deposit">deposit</option>
                  <option value="paid">paid</option>
                </select>
              </div>

              <div class="overflow-x-auto rounded-2xl border border-white/10">
                <table class="w-full text-sm">
                  <thead class="bg-white/5 text-[#A8B0C2]">
                    <tr>
                      <th class="text-left p-3">Date/Heure</th>
                      <th class="text-left p-3">Client</th>
                      <th class="text-left p-3">Trajet</th>
                      <th class="text-left p-3">Véhicule</th>
                      <th class="text-left p-3">Prix</th>
                      <th class="text-left p-3">Paiement</th>
                      <th class="text-left p-3">Statut</th>
                      <th class="text-right p-3">Actions</th>
                    </tr>
                  </thead>
                  <tbody id="reservationsBody" class="text-white"></tbody>
                </table>
              </div>
              <div id="reservationsEmpty" class="hidden text-center text-[#A8B0C2] py-10">Aucune réservation.</div>
            </div>

            <div class="glass-panel p-6 rounded-2xl">
              <h3 class="text-lg font-bold text-white mb-2">Raccourcis</h3>
              <div class="space-y-3">
                <button onclick="app.navigate('clients')" class="w-full px-4 py-3 rounded-2xl bg-white/5 hover:bg-white/10 text-white text-sm text-left">
                  <i class="fas fa-users mr-2"></i>Clients
                </button>
                <button onclick="app.navigate('drivers')" class="w-full px-4 py-3 rounded-2xl bg-white/5 hover:bg-white/10 text-white text-sm text-left">
                  <i class="fas fa-id-card mr-2"></i>Chauffeurs
                </button>
                <button onclick="app.navigate('rides')" class="w-full px-4 py-3 rounded-2xl bg-white/5 hover:bg-white/10 text-white text-sm text-left">
                  <i class="fas fa-car mr-2"></i>Courses
                </button>
              </div>
              <div class="mt-6 p-4 rounded-2xl bg-white/5 border border-white/10">
                <div class="text-xs text-[#A8B0C2]">Note</div>
                <div class="text-sm text-white mt-1">Le formulaire de réservation côté site envoie dans Supabase via une Netlify Function.</div>
              </div>
            </div>
          </div>
        `;

        const apply = () => this.renderReservations();
        document.getElementById('resQ').addEventListener('input', apply);
        document.getElementById('resStatus').addEventListener('change', apply);
        document.getElementById('resPay').addEventListener('change', apply);

        await this.refreshReservations();
      },

      async refreshReservations() {
        const res = await this.apiCall('/admin-reservations-list', { method: 'GET' });
        const data = await res.json().catch(() => ({}));
        state.reservations = Array.isArray(data.rows) ? data.rows : [];
        this.renderReservations();
      },

      renderReservations() {
        const rows = state.reservations || [];
        const q = (document.getElementById('resQ')?.value || '').toLowerCase().trim();
        const st = (document.getElementById('resStatus')?.value || '').toLowerCase().trim();
        const pay = (document.getElementById('resPay')?.value || '').toLowerCase().trim();

        const filtered = rows.filter(r => {
          const blob = [r.client_name,r.client_email,r.client_phone,r.pickup,r.dropoff,r.vehicle].map(x=>String(x||'').toLowerCase()).join(' ');
          const okQ = !q || blob.includes(q);
          const okSt = !st || String(r.status||'').toLowerCase() === st;
          const okPay = !pay || String(r.payment_status||'').toLowerCase() === pay;
          return okQ && okSt && okPay;
        });

        const body = document.getElementById('reservationsBody');
        const empty = document.getElementById('reservationsEmpty');
        body.innerHTML = '';
        if (!filtered.length) { empty.classList.remove('hidden'); return; }
        empty.classList.add('hidden');

        const eur = (n) => new Intl.NumberFormat('fr-FR', { style:'currency', currency:'EUR' }).format(Number(n || 0));
        const dt = (iso) => { try { return new Date(iso).toLocaleString('fr-FR'); } catch { return String(iso||''); } };

        filtered.forEach(r => {
          const tr = document.createElement('tr');
          tr.className = 'border-t border-white/10 hover:bg-white/5';
          tr.innerHTML = `
            <td class="p-3">${dt(r.datetime)}</td>
            <td class="p-3">
              <div class="font-medium">${escapeHtml(r.client_name || '')}</div>
              <div class="text-xs text-[#A8B0C2]">${escapeHtml(r.client_email || '')}</div>
            </td>
            <td class="p-3">
              <div class="font-medium">${escapeHtml(r.pickup || '')}</div>
              <div class="text-xs text-[#A8B0C2]">→ ${escapeHtml(r.dropoff || '')}</div>
            </td>
            <td class="p-3">${escapeHtml(r.vehicle || 'berline')}</td>
            <td class="p-3 font-semibold text-[#D6B15E]">${eur(r.price_eur)}</td>
            <td class="p-3">${this.badgePay(r.payment_status)}</td>
            <td class="p-3">${this.badgeStatus(r.status)}</td>
            <td class="p-3 text-right space-x-2">
              <button onclick="app.setReservationStatus('${r.id}','confirmed')" class="px-3 py-1.5 rounded-xl bg-white/5 hover:bg-white/10 text-white text-xs">Confirmer</button>
              <button onclick="app.setReservationStatus('${r.id}','completed')" class="px-3 py-1.5 rounded-xl bg-white/5 hover:bg-white/10 text-white text-xs">Terminer</button>
              <button onclick="app.openQuoteFromReservation('${r.id}')" class="px-3 py-1.5 rounded-xl gold-gradient text-black text-xs font-semibold">
                <i class="fas fa-link mr-1"></i>Devis+Stripe
              </button>
            </td>
          `;
          body.appendChild(tr);
        });
      },

      badgePay(v) {
        const x = String(v||'unpaid').toLowerCase();
        if (x==='paid') return `<span class="px-2 py-1 rounded-xl text-xs bg-green-500/15 text-green-300 border border-green-500/20">paid</span>`;
        if (x==='deposit') return `<span class="px-2 py-1 rounded-xl text-xs bg-amber-500/15 text-amber-300 border border-amber-500/20">deposit</span>`;
        return `<span class="px-2 py-1 rounded-xl text-xs bg-white/5 text-[#A8B0C2] border border-white/10">unpaid</span>`;
      },

      badgeStatus(v) {
        const x = String(v||'pending').toLowerCase();
        if (x==='completed') return `<span class="px-2 py-1 rounded-xl text-xs bg-green-500/15 text-green-300 border border-green-500/20">completed</span>`;
        if (x==='confirmed') return `<span class="px-2 py-1 rounded-xl text-xs bg-blue-500/15 text-blue-300 border border-blue-500/20">confirmed</span>`;
        if (x==='cancelled') return `<span class="px-2 py-1 rounded-xl text-xs bg-red-500/15 text-red-300 border border-red-500/20">cancelled</span>`;
        return `<span class="px-2 py-1 rounded-xl text-xs bg-white/5 text-[#A8B0C2] border border-white/10">pending</span>`;
      },

      async setReservationStatus(id, status) {
        const res = await this.apiCall('/admin-reservations-update', { method:'POST', body: JSON.stringify({ id, status }) });
        const data = await res.json().catch(()=>({}));
        if (!res.ok || !data.ok) return this.showToast(data.error || 'Erreur', 'error');
        await this.refreshReservations();
        this.showToast('Mise à jour ✅', 'success');
      },

      openQuoteFromReservation(id) {
        const r = (state.reservations || []).find(x => x.id === id);
        if (!r) return;
        this.showModal('newQuote');
        const desc = `Réservation SHVIP: ${r.pickup} → ${r.dropoff} (${new Date(r.datetime).toLocaleString('fr-FR')})`;
        const set = (ids, v) => { for (const i of ids) { const el = document.getElementById(i); if (el) { el.value = v; return; } } };
        set(['quoteCustomerEmail','customerEmail','qCustomerEmail'], r.client_email || '');
        set(['quoteCustomerName','customerName','qCustomerName'], r.client_name || '');
        set(['quoteDescription','description','qDescription'], desc);
        set(['quoteTotalAmount','totalAmount','qTotalAmount'], r.price_eur || '');
      },

      async createReservationFromModal() {
        const v = (id) => (document.getElementById(id)?.value || '').trim();
        const payload = {
          client_name: v('resClientName'),
          client_email: v('resClientEmail'),
          client_phone: v('resClientPhone'),
          pickup: v('resPickup'),
          dropoff: v('resDropoff'),
          datetime: v('resDatetime'),
          vehicle: v('resVehicle') || 'berline',
          price_eur: Number(v('resPrice') || 0),
          notes: v('resNotes')
        };

        if (!payload.client_name || !payload.client_email || !payload.pickup || !payload.dropoff || !payload.datetime || !payload.price_eur) {
          this.showToast('Champs requis manquants.', 'error');
          return;
        }

        const res = await this.apiCall('/admin-reservations-create', { method:'POST', body: JSON.stringify(payload) });
        const data = await res.json().catch(()=>({}));
        if (!res.ok || !data.ok) { this.showToast(data.error || 'Erreur', 'error'); return; }

        this.closeModal('reservation');
        this.showToast('Réservation créée ✅', 'success');
        await this.refreshReservations();
      },

async loadPayments() {
